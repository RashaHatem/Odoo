<?xml version='1.0' encoding='utf-8'?>
<odoo>
   
        
        <record id="update_fees_wizard" model="ir.ui.view">
            <field name="name">Update Fees</field>
            <field name="model">student.fees.update.wizard</field>
            <field name="arch" type="xml">
                <form>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="total_fees"/>
                        </group>
                    </group>
                    <footer>
                        <button name="action_update_fees" 
                                type="object" 
                                string="update"
                                class="btn btn-primary"/>
                        <button special="cancel"
                                string='cancel'
                                class="btn btn-secondary"/>
                    </footer>
                </form>
            </field>        
        </record>

        <record id="update_student_fees_action" model="ir.actions.act_window">
                <field name="name">Update Fees</field>
                <field name="res_model">student.fees.update.wizard</field>
                <field name="view_mode">form</field>
                <field name="target">new</field>
        </record>

        

        <record id="update_fees_action_window" model="ir.actions.act_window">
            <field name="name">Update Student Fees</field>
            <field name="res_model">student.fees.update.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="view_id" ref="update_fees_wizard"/>
            <field name="binding_model_id" ref="model_school_student"/>
        </record>

        <menuitem
            id="wizard_menu"
            name="Update Student Fees"
            parent="school_student.school_student_menu"
            action="update_student_fees_action"
            />
        
  
</odoo>