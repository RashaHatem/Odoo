    <record id="student_kanban" model="ir.ui.view">
        <field name="name">student.kanban.view</field>
        <field name="model">school.student</field>
        <field name="arch" type="xml">
            <kanban  
                groups_draggable="false"
                highlight_color="color"   
                records_draggable="false"   
                class="o_kanban_small_column m-3" 
                quick_create="false"
                create="false">
                <field name="name" />
                <field name="school_id"/>
                <field name="color"/>
                <field name="absence_count"/>
                <field name="priority"/>
                <field name="state_"/>
                <field name="hobby_list"/>

                
                <progressbar 
                        field="state_"
                        colors='{"accepted": "success", "rejected": "danger", "draft": "secondary"}'
                        sum_field="absence_count"
                />
                <templates >
                    <header>
                    <button 
                        name="action_done" 
                        type="object" 
                        string="ظاهر دائماً" 
                        display="always"
                        class="btn btn-primary"
                    />
                </header>
                    <t t-name="card">
                       
                        <div t-attf-class="oe_kanban_global_click d-flex flex-row">
                       <aside>
                            <div class="o_kanban_image me-3 mt-2">
                                <img t-attf-src="/web/image/school.student/#{record.id.raw_value}/image_128"
                                     class="rounded-circle border border-2"
                                     options="{'size':[100,100]}"/>
                            </div>
                       </aside>
                       <main>
                        <a type="open"
                           class="o_kanban_title">
                        
                                <strong class="d-block"><field name="name"/></strong>
                                
                        </a>
                        
                        <field name="school_id"/>
                        <footer>
                                <field name="hobby_list" 
                                widget="many2many_tags"
                                class="d-block"
                                />
                                <field name="priority" widget="priority"/>
                        </footer>
                       </main>
                       </div>
                       
                    </t>
                    <t t-name="menu">
                        <a role="menuitem" type="edit" class="dropdown-item"><i class="fa fa-edit"/>  update</a>
                        <a role="menuitem" type="delete" class="dropdown-item"><i class="fa fa-trash-o"/>  delete</a>
                        <a role="menuitem" type="set_cover" class="dropdown-item">set cover</a>
                        <a role="menuitem" type="archive" class="dropdown-item"><i class="fa fa-archive"/>  archive</a>
                        <a role="menuitem" type="unarchive" class="dropdown-item">unarchive</a>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

