                    </group>
                </group>
            </form>
        </field>
    </record>
    <record id="search_school_student" model="ir.ui.view">
        <field name="name">Search School Student</field>
        <field name="model">school.student</field>
        <field name="arch" type="xml">
            <search string="Serch view">
                <searchpanel>
                    <field 
            name="school_id" 
            string="Schools" 
            select="one" 
            icon="fa-building" 
            color="#714B27"
            widget="many2one_selectable"
            hierarchize="1"
        />
                    <field 
            name="hobby_list" 
            string="Hobbies" 
            select="multi" 
            icon="fa-users" 
            enable_counters="1"            
            
            
            
        />
                    <!-- <field>
            <button name="action_done" type="object" string="done"/>
        </field> -->
                </searchpanel>
                <!-- <field name="name" string="Name"/>
                <field name="school_id" string="Schoooool Name"/> -->
                <field name="name"
                       string="Search for --> " 
                        filter_domain="['|',('name', 'ilike', self),('school_id','ilike',self)]"
                 />
                <filter string="High priority"
                        name="priority"
                        domain="[('priority', '=', '2')]"
                        />
                <filter string="active"
                        name="active"
                        domain="[('active', '=', 'true')]"
                        />
                <filter string="less absence"
                        name="absence_count"
                        domain="[('absence_count', '&lt;', 3)]"
                        />
                <filter 
                        string="Creation Date" 
                        name="filter_create_date" 
                        date="create_date"
                        />
                <filter name="last_7_dayes"
                        string="Last week"
                        domain="[('create_date','>',(context_today()-relativedelta(days=7)).strftime('%Y-%m-%d'))]"
                        />
                <group expand="1" string="Group By">
                    <filter string="High priority"
                                name="priority"
                                context="{'group_by': 'priority' }"
                                
                        />
                    <filter string="less absence"
                                name="absence_count"
                                context="{'group_by': 'absence_count' }"
                                
                        />
                </group>
            </search>
        </field>
    </record>
