<?xml version="1.0" encoding="utf-8"?>
<odoo>
   
    <!-- List_view -->
    <record id="student_list_view" model="ir.ui.view">
        <field name="name">student.list.view</field>
        <field name="model">school.student</field>
        <field name="arch" type="xml">
            <list>
                <!-- decoration-danger="state =='suspended'" default_group_by="school_id" expand="1" > -->
                <!-- default_group_by="school_id" expand="1" -->
                <!-- groups_limit="2" -->
                <header>
                    <button name="reload_page" type="object" string="reload" class="btn-primary" display="always"/>
                </header>
                <groupby name="school_id" >
                    <button 
            type="object" 
            name="print_school_name" 
            icon="fa-users" 
            title="print school name"
            />
                </groupby>

                <field name="image_128" 
                column_invisible="True"
                />
                <field  name="name" 
                        widget="name_with_avatar" 
                        options="{'avatar_field': 'image_128'}"
                        decoration-bf="1"/>
                
                <field name="school_id"/>
                <button name="%(action_hobbies)d"
                    string="action type"
                    type="action"
                    icon="fa-check"
                    invisible="state_ != 'draft'"
                    class="btn-scondary" />
                <field name="state" widget="badge"
                    decoration-success="state == 'active'"
                />
                <field name="absence_count" 
                       widget="progressbar" 

                       
                       />
                       <!-- options="{'current_value': 'absence_count', 'max_value': 100, 'editable': true}" -->
                <button name="action_done"
                    string="refresh"
                    type="object"
                    icon="fa-refresh"
                    invisible="state_ != 'draft'"
                    class="btn-primary"
                    title="Che"
                    confirm="Are you sure?"
                    column_invisible="context.get('hide_confirm')"
                />
                <button name="unlink"
                    type="object"
                    icon="fa-trash"
                />
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    
    <record id="school_student_pivot" model="ir.ui.view">
        <field name="name">School Student Pivot</field>
        <field name="model">school.student</field>
        <field name="arch" type="xml">
            <pivot string="Pivot view" disable_linking="1">
                <field name="school_id" type="row"/>
                
                <field name="absence_count" type="measure"/>

            </pivot>
        </field>
    </record>

    <record id="school_student_calendar" model="ir.ui.view">
        <field name="name">School Student Calendar</field>
        <field name="model">school.meeting</field>
        <field name="arch" type="xml">
            <calendar string="Calendar View"
                     date_start="start_date"
                     date_stop="end_date" 
                     color="user_id"
                     quick_create="true"
                     event_open_popup="true">

                <field name="name"/>
                <field 
                       name="user_id" 
                       filters="1" 
                       avatar_field="image_128"
    />
            </calendar>
        </field>
    </record>

   <record id="graph_school_student" model="ir.ui.view">
    <field name="name">Graph School Student</field>
    <field name="model">school.student</field>
    <field name="arch" type="xml">
        
        <graph string="Graph" type="bar" stacked="1" sample="1" disable_linking="1">
            <field name="name"/>
            <field name="school_id"/>
            <field name="absence_count" type="measure"/>
        </graph>
    </field>
   </record>

   <record id="activity_school_student" model="ir.ui.view">
    <field name="name">Activity School Student</field>
    <field name="model">school.meeting</field>
    <field name="arch" type="xml">
        <activity string="Activity">
            <field name="name"/>
            <field name="meeting_type"/>
            <field name="user_id"/>

            <templates>
                <t t-name="activity-box">
                    <div class="d-flex justify-content-between">
                <strong class="o_activity_record_title">
                    <field name="name"/>
                </strong>
                
                <span t-if="record.meeting_type.raw_value == 'admin' or record.meeting_type.value == 'admin'" 
                      class="fa fa-university text-danger" 
                      title="adminastritor"/>
            </div>

            <div class="text-muted small">
                responsbility: <t t-esc="record.user_id.value"/>
            </div>
                </t>
            </templates>
        </activity>
    </field>

   </record>
   
    <record id="hobby_list_view" model="ir.ui.view">
        <field name="name">hobby.list.view</field>
        <field name="model">hobbies</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
            </list>
        </field>
    </record>
    <record id="school_extend_form" model="ir.ui.view">
        <field name="name">School extend form</field>
        <field name="model">school.profile</field>
        <field name="inherit_id" ref="school.school_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//page[@name= 'details'] " position="after">
                <page string="Student List" name="ds">
                    <field name="student_count_"
                        invisible="student_count_ == 0"
                    />
                    <field name="school_list">
                        <list>
                            <field name="name" decoration-info="parent.is_virtual_class == True" />
                            <control>
                                <create string="Add student" 
                    context="{'default_name': 'Salem','default_display_type':'add line' }"
                    />
                            </control>
                        </list>
                        <form>
                            <group>
                                <field name="name" />
                            </group>
                        </form>
                    </field>
                </page>
            </xpath>
            <xpath expr="//button[@name='action_view_related_records']" position="inside">
                <span>
                    <field name="student_count_"
                        invisible="student_count_ == 0 "
                    /> Student
                </span>
            </xpath>
        </field>
    </record>
    <!-- Form -->
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="المدرسة" string="إعدادات المدرسة" name="school">
                    <block title="إعدادات الطلاب">
                        <setting type="hedar" string="الغياب">
                            <field name="max_absence_days" />
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
    <record id="student_form_view" model="ir.ui.view">
        <field name="name">student.form.view</field>
        <field name="model">school.student</field>
        <field name="arch" type="xml">
            <form>
                <header class="my_custom_header">
                    <button name="action_submit"
                        string="تقديم الطلب"
                        type="object"
                        class="btn-primary"
                        invisible="state_ != 'draft'" />
                    <button name="action_accept"
                        string="قبول"
                        type="object"
                        class="btn-primary"
                        invisible="state_ != 'submitted'" />
                    <button name="action_reject"
                        string="رفض"
                        type="object"
                        invisible="state_ != 'submitted'" />
                    <button name="action_draft"
                        string="إعادة للمسودة"
                        type="object"
                        invisible="state_ != 'rejected'" />
                    <field name="state_"
                        widget="statusbar"
                        statusbar_visible="draft,submitted,accepted" />
                    <!-- <button name="action_done" string="Save"
                        type="object"
                        class="oe_highlight" /> -->
                </header>
                <sheet>
                    <div class="alert alert-warning text-center o_form_header"
                        role="status"
                        invisible="state_ != 'draft'">
                        <i class="fa fa-info-circle me-1" />
                        <strong>ملاحظة:</strong> هذا السجل لا
                        يزال مسودة، يمكنك تعديله بحرية.
                    </div>
                    <widget name="web_ribbon" title="مقبول" bg_color="bg-success"
                        invisible="state_ != 'accepted'" />
                    <widget name="web_ribbon" title="مرفوض" bg_color="bg-danger"
                        invisible="state_ != 'rejected'" />
                    <group>
                        <group>
                            <field name="name" />
                            <!-- <field name="image" 
                            widget="image" class="oe_avatar rounded-circle" 
                            options="{'preview_image': 'image', 'size': [90, 90]}"
                            /> -->
                            <label for="image_128" string="Profile Photo"/>
                            <div class="d-flex align-items-center">
                                <field name="image_128" 
                                    widget="image" 
                                    class="oe_avatar" 
                                    style="object-fit: cover !important; width: 90px; height: 90px; overflow: hidden;"
                                    options="{'size': [90, 90],'zoom':true}"/>
                            </div>
                            <field name="school_id" widget="selection" />
                            <field name="active" widget="boolean_toggle"/>
                            <field name="hobby_list" 
                                widget="many2many_checkboxes"
                                
                                
                            />

                            <field name="absence_count"
                            />
                            <field name="state" />
                            <field name="priority" widget="priority"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="hobby_form_view" model="ir.ui.view">
        <field name="name">hobby.form.view</field>
        <field name="model">hobbies</field>
        <field name="arch" type="xml">
            <form>
                <group>
