<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--              List View                   -->
    <record id="school_list_view" model="ir.ui.view">
        <field name="name">school.list.view</field>
        <field name="model">school.profile</field>
        <field name="arch" type="xml">
            <list  
            
            editable="top" open_form_view="True"
            multi_edit="True" 
            default_order="phone desc" limit="3"
            
            
            >
                <field name="name"/>
                <field name="email" optional="show"/>
                <field name="phone" optional="hide"/>
                <field name="is_virtual_class"  />
            </list>
        </field>
    </record>

    <!--              Form View                   -->
    <record id= "school_form_view" model="ir.ui.view">
        <field name="name">school.form.view</field>
        <field name="model">school.profile</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="print_word" 
                        string="Confirm Subscription" 
                        type="object" 
                        class="btn-primary"/>
                    <button name="print_word" 
                        string="Cancel" 
                        type="object" 
                        class="btn-secondary"
                        icon="fa-money"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_related_records" 
                            type="object" 
                            class="oe_stat_button" 
                            icon="fa-users">
                        </button>
                    </div>
                    <!-- <label for="name" string="LABEL"/>
        
            <field name="name" class="oe_inline"/> -->
                    <!-- <div class="oe_button_box" name="button_box">
            <button name="print_word" 
                    type="object" 
                    class="oe_stat_button" 
                    icon="fa-money">
                <field name="name" 
                       widget="statinfo" 
                       string="Payments"/>
            </button>
        </div> -->
                    <group >
                        <group>
                            <field name="name"/>
                            <field name="email" />
                            <field name="phone"/>
                            <field name="is_virtual_class" widget="boolean_toggle"/>
                        </group>
                        <!-- <newline/> -->
                        <group>
                            <field name="currency_id" />
                            <field name="fees"/>
                            <field name="active" widget="boolean_button" options="{'terminology': 'active'}"/>
                            <field name="date"/>
                            <field name="school_type"/>
                            <field name="message" widget="html" options="{'collaborative': True, 'resizable': True}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Schools" name="details">
                            <field name="name"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="o_attachment_preview" 
                invisible="attachment_ids == []"
                />
                <chatter/>
                <!-- <div class="oe_chatter">
                  <field name="message_follower_ids" widget="mail_followers" />
                  <field name="activity_ids" widget="mail_activity"/>
                  <field name="message_ids" widget="mail_thread" />
              </div> -->
            </form>
        </field>
    </record>

  

    <record id="action_school_profile" model="ir.actions.act_window">
        <field name="name">School Profile</field>
        <field name="res_model">school.profile</field>
        <field name="view_mode">list,form</field>
    </record>

    

    <menuitem id="school_root_menu" name="School Management" />
    <menuitem id="school_sub_menu" name="Configuration" parent="school_root_menu"/>
    <menuitem id="school_profile_menu" name="School Profiles" action="action_school_profile" parent="school_sub_menu" />
</odoo>